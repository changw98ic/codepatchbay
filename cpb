  case "$sub" in
    reconcile)
      shift || true
      CPB_ROOT="$CPB_ROOT" CPB_EXECUTOR_ROOT="$CPB_EXECUTOR_ROOT" node "$CPB_EXECUTOR_ROOT/bridges/reconcile.mjs" "$@"
