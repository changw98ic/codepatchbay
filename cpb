      if echo "$*" | grep -q '\-\-dry-run'; then
        echo -e "${BOLD}Cleanup dry-run report...${NC}"
        CPB_ROOT="$CPB_ROOT" CPB_EXECUTOR_ROOT="$CPB_EXECUTOR_ROOT" node --input-type=module -e "
          import path from 'node:path';
          const cpbRoot = path.resolve(process.env.CPB_ROOT || '.');
          const executorRoot = path.resolve(process.env.CPB_EXECUTOR_ROOT || cpbRoot);
          const { cleanupDryRun } = await import(path.join(executorRoot, 'server/services/reconcile.js'));
          const report = await cleanupDryRun(cpbRoot);
          console.log('Total jobs:', report.totalJobCount);
          console.log('Lease files:', report.totalLeaseFiles);
          console.log('Would remove leases (' + report.leasesToRemove.length + '):');
          for (const id of report.leasesToRemove) console.log('  ' + id);
          console.log('Worktrees preserved (' + report.worktreesPreserved.length + '):');
          for (const w of report.worktreesPreserved) console.log('  ' + w.jobId + ' (' + w.status + '): ' + w.worktree);
        "
      else
        echo -e "${BOLD}Cleaning up stale leases...${NC}"
        CPB_ROOT="$CPB_ROOT" CPB_EXECUTOR_ROOT="$CPB_EXECUTOR_ROOT" node --input-type=module -e "
