cmd_clean() {
  local dry_run=0
  for arg in "$@"; do
    case "$arg" in
      --dry-run) dry_run=1 ;;
    esac
  done
  CPB_ROOT="$CPB_ROOT" CPB_EXECUTOR_ROOT="$CPB_EXECUTOR_ROOT" CPB_CLEAN_DRY_RUN="$dry_run" node --input-type=module - <<'CLEAN_NODE'
import path from "node:path";
const cpbRoot = path.resolve(process.env.CPB_ROOT);
const executorRoot = path.resolve(process.env.CPB_EXECUTOR_ROOT || cpbRoot);
const dryRun = process.env.CPB_CLEAN_DRY_RUN === "1";
const { cleanProcesses } = await import(path.join(executorRoot, "server/services/process-registry.js"));
const result = await cleanProcesses(cpbRoot, { dryRun });

if (dryRun) {
  console.log(`Dry run: ${result.eligible.length} eligible entries`);
  for (const e of result.eligible) {
    console.log(`  ${e.jobId} ${e.status} project:${e.project || "-"}`);
  }
} else {
  console.log(`Removed ${result.removed.length} process registry entries`);
  for (const id of result.removed) console.log(`  ${id}`);
}
CLEAN_NODE
}

