#!/usr/bin/env bash
set -euo pipefail

# cpb — CodePatchbay CLI for Codex + Claude Code ACP handoffs
# Usage: cpb <command> [args...]

CPB_ROOT="$(cd "$(dirname "$0")" && pwd)"
CPB_VERSION="0.2.0"

# Parse global flags
DANGEROUS=0
for arg in "$@"; do
  case "$arg" in
    --dangerous) DANGEROUS=1; export CPB_DANGEROUS=1 ;;
  esac
done
# Strip --dangerous from args so subcommands don't see it
filtered_args=()
for arg in "$@"; do
  [ "$arg" = "--dangerous" ] && continue
  filtered_args+=("$arg")
done
set -- "${filtered_args[@]}"

# Colors (defined here so they're always available even if source fails)
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

# shellcheck source=bridges/common.sh
source "$CPB_ROOT/bridges/common.sh" 2>/dev/null || true

usage() {
  cat << EOF
${BOLD}cpb${NC} v$CPB_VERSION — CodePatchbay

${BOLD}Usage:${NC}
  cpb <command> [arguments]

${BOLD}Commands:${NC}
  ${CYAN}init${NC} <path> <name>                    初始化项目集成
  ${CYAN}plan${NC} <project> "<task>"               Codex 规划
  ${CYAN}execute${NC} <project> <plan-id>            Claude 执行
  ${CYAN}verify${NC} <project> <deliverable-id>      Codex 验证
  ${CYAN}research${NC} <project> "<task>"              双 agent 协同研究
  ${CYAN}diff${NC} <project>                           查看项目源码变更
  ${CYAN}pipeline${NC} [--interactive] <project> "<task>" [retries]  全自动流水线
  ${CYAN}cancel${NC} <project> <jobId> [reason]      请求取消运行中的 job
  ${CYAN}redirect${NC} <project> <jobId> "<instructions>" [reason]  重定向运行中的 job
  ${CYAN}status${NC} <project>                       查看项目状态
  ${CYAN}list${NC}                                   列出所有项目
  ${CYAN}jobs${NC}                                     列出 durable jobs
  ${CYAN}supervisor${NC}                               启动长时运行 supervisor 原型
  ${CYAN}migrate-runtime-root${NC} [--quarantine-non-cpb] 迁移旧运行时数据到 cpb-task/
  ${CYAN}wiki${NC} [lint|list]                       Wiki 操作
  ${CYAN}ui${NC} [--port PORT] [--host HOST]        启动 Web UI (默认 127.0.0.1)

${BOLD}Global flags:${NC}
  ${YELLOW}--dangerous${NC}                            移除 ACP 权限约束（unrestricted mode）
  ${CYAN}interop${NC}                                启动分屏协作
  ${CYAN}install${NC}                                安装到 PATH

${BOLD}Examples:${NC}
  cpb init ./my-project my-project
  cpb plan my-project "Add dark mode"
  cpb execute my-project 001
  cpb verify my-project 001
  cpb pipeline my-project "Add unit tests" 3 30
  cpb research my-project "Add dark mode"
  cpb pipeline --interactive my-project "Add dark mode"
EOF
}

check_deps() {
  local missing=()
  command -v node &>/dev/null || missing+=("node")
  [ -x "$CPB_ROOT/bridges/acp-client.mjs" ] || missing+=("acp-client.mjs (run: chmod +x bridges/acp-client.mjs)")

  if [ ${#missing[@]} -gt 0 ]; then
    echo -e "${YELLOW}Missing:${NC}"
    for d in "${missing[@]}"; do echo "  - $d"; done
    return 1
  fi
  echo -e "${GREEN}ACP client ready.${NC}"
}

cmd_init()     { "$CPB_ROOT/bridges/init-project.sh" "$@"; }
cmd_plan()     { "$CPB_ROOT/bridges/codex-plan.sh" "$@"; }
cmd_execute()  { "$CPB_ROOT/bridges/claude-execute.sh" "$@"; }
cmd_verify()   { "$CPB_ROOT/bridges/codex-verify.sh" "$@"; }
cmd_research() {
  local project="${1:?Usage: cpb research <project> '<task>'}"
  local task="${2:?Usage: cpb research <project> '<task>'}"
  "$CPB_ROOT/bridges/dual-research.sh" "$project" "$task"
}

cmd_diff() {
  local project="${1:?Usage: cpb diff <project>}"
  require_safe_name "$project"
  require_project "$project"
  local src
  src=$(get_project_path "$project")
  if [ -z "$src" ] || [ ! -d "$src" ]; then
    echo -e "${RED}Project source path not found: $src${NC}" >&2
    exit 1
  fi
  if [ ! -d "$src/.git" ]; then
    echo -e "${RED}Not a git repository: $src${NC}" >&2
    exit 1
  fi
  git -C "$src" diff --stat
  echo ""
  git -C "$src" diff
}

cmd_pipeline() {
  if [ "${1:-}" = "--interactive" ]; then
    shift
    cmd_pipeline_interactive "$@"
  else
    "$CPB_ROOT/bridges/run-pipeline.sh" "$@"
  fi
}

cmd_pipeline_interactive() {
  local project="${1:?Usage: cpb pipeline --interactive <project> '<task>'}"
  local task="${2:?Usage: cpb pipeline --interactive <project> '<task>'}"
  local max_retries="${3:-3}"

  # TTY check
  if [[ ! -t 0 || ! -t 1 ]]; then
    echo -e "${RED}--interactive mode requires a terminal (TTY).${NC}" >&2
    exit 1
  fi

  require_safe_name "$project"
  require_project "$project"

  local wiki_dir="$CPB_ROOT/wiki/projects/$project"
  local research_file plan_file plan_id

  # Phase 1: Research
  echo -e "\n${BOLD}Phase 1/4: Research (dual-agent)${NC}"
  research_file=$("$CPB_ROOT/bridges/dual-research.sh" "$project" "$task" | tail -1 | sed 's/^Research: //')
  if [ ! -f "$research_file" ]; then
    echo -e "${RED}Research failed.${NC}" >&2
    exit 1
  fi
  echo -e "  ${GREEN}Research done:${NC} $research_file"

  # Phase 2: Plan (with research)
  echo -e "\n${BOLD}Phase 2/4: Plan (Codex)${NC}"
  plan_file=$("$CPB_ROOT/bridges/codex-plan.sh" "$project" "$task" "$research_file" | grep '^Plan: ' | sed 's/^Plan: //')
  if [ ! -f "$plan_file" ]; then
    echo -e "${RED}Plan generation failed.${NC}" >&2
    exit 1
  fi
  plan_id=$(basename "$plan_file" .md | sed 's/^plan-//')
  echo -e "  ${GREEN}Plan done:${NC} $plan_file"

  # Phase 3: Show plan + user confirmation
  echo -e "\n${BOLD}Phase 3/4: Review Plan${NC}"
  echo ""
  "$CPB_ROOT/bridges/show-plan.sh" "$plan_file"
  echo ""

  local answer
  while true; do
    read -rp "$(echo -e "${CYAN}Confirm execute? [y/n/e(edit task)]: ${NC}")" answer
    case "$answer" in
      [yY])
        break
        ;;
      [nN])
        echo -e "${YELLOW}Aborted. Plan saved: $plan_file${NC}"
        echo "  To execute later: cpb execute $project $plan_id"
        exit 0
        ;;
      [eE])
        read -rp "$(echo -e "${CYAN}New task description: ${NC}")" task
        echo -e "\n${BOLD}Re-generating plan...${NC}"
        plan_file=$("$CPB_ROOT/bridges/codex-plan.sh" "$project" "$task" "$research_file" | grep '^Plan: ' | sed 's/^Plan: //')
        if [ ! -f "$plan_file" ]; then
          echo -e "${RED}Plan regeneration failed.${NC}" >&2
          exit 1
        fi
        plan_id=$(basename "$plan_file" .md | sed 's/^plan-//')
        echo ""
        "$CPB_ROOT/bridges/show-plan.sh" "$plan_file"
        echo ""
        ;;
      *)
        echo "  Please enter y, n, or e."
        ;;
    esac
  done

  # Phase 4: Execute + Verify (skip plan in pipeline)
  echo -e "\n${BOLD}Phase 4/4: Execute + Verify${NC}"
  exec node "$CPB_ROOT/bridges/run-pipeline.mjs" \
    --project "$project" \
    --task "$task" \
    --max-retries "$max_retries" \
    --skip-plan \
    --plan-id "$plan_id"
}
cmd_jobs()      { CPB_ROOT="$CPB_ROOT" "$CPB_ROOT/bridges/list-jobs.mjs"; }
cmd_supervisor() { CPB_ROOT="$CPB_ROOT" "$CPB_ROOT/bridges/supervisor-loop.mjs"; }
cmd_migrate_runtime_root() { CPB_ROOT="$CPB_ROOT" "$CPB_ROOT/bridges/migrate-runtime-root.mjs" "$@"; }

cmd_status() {
  local project="${1:?Usage: cpb status <project>}"
  local wdir="$CPB_ROOT/wiki/projects/$project"
  require_project "$project"

  echo -e "${BOLD}Project: $project${NC}"
  echo ""

  [ -f "$wdir/context.md" ] && { echo -e "${CYAN}Context:${NC}"; grep "^- \*\*" "$wdir/context.md" | head -5; echo ""; }

  [ -f "$wdir/tasks.md" ] && { echo -e "${CYAN}Tasks:${NC}"; grep -E "TASK-|PENDING|IN_PROGRESS|DONE|BLOCKED" "$wdir/tasks.md" 2>/dev/null | head -10 || echo "  None"; echo ""; }

  [ -f "$wdir/log.md" ] && { echo -e "${CYAN}Recent:${NC}"; grep "^- \*\*" "$wdir/log.md" | tail -5; echo ""; }

  local inbox=$(ls "$wdir/inbox/"*.md 2>/dev/null | wc -l | tr -d ' ')
  local outputs=$(ls "$wdir/outputs/"*.md 2>/dev/null | wc -l | tr -d ' ')
  echo -e "${CYAN}Inbox:${NC} $inbox  ${CYAN}Outputs:${NC} $outputs"

  # Pipeline state from durable job projection
  local state
  state=$(node -e "
    import('${CPB_ROOT}/server/services/job-projection.js').then(m =>
      m.projectPipelineState('${CPB_ROOT}', '${project}')
    ).then(s => s ? s.status + ' ' + (s.phase || '') : '')
    .catch(() => '')
  " 2>/dev/null)
  if [ -n "$state" ]; then
    echo -e "${CYAN}Pipeline:${NC} $state"
  fi
}

cmd_list() {
  echo -e "${BOLD}CodePatchbay Projects:${NC}"
  local found=0
  for dir in "$CPB_ROOT/wiki/projects"/*/; do
    [ -d "$dir" ] || continue
    local name=$(basename "$dir")
    [ "$name" = "_template" ] && continue
    found=1
    local inbox=$(ls "$dir/inbox/"*.md 2>/dev/null | wc -l | tr -d ' ')
    local outputs=$(ls "$dir/outputs/"*.md 2>/dev/null | wc -l | tr -d ' ')
    echo -e "  ${CYAN}$name${NC}  inbox:$inbox  out:$outputs"
  done
  [ "$found" -eq 0 ] && echo "  None. Run: cpb init <path> <name>"
  return 0
}

cmd_wiki() {
  local sub="${1:-list}"
  case "$sub" in
    list)
      echo -e "${BOLD}Wiki:${NC}"
      find "$CPB_ROOT/wiki" -type f -name "*.md" | sort | sed "s|$CPB_ROOT/wiki/||"
      ;;
    lint)
      echo "Wiki health check..."
      local issues=0

      # System files
      for f in schema.md system/handshake-protocol.md system/memory-routing.md system/skill-registry.md system/team-prd.md system/team-architecture.md system/dashboard.md system/unattended-supervisor.md; do
        [ ! -f "$CPB_ROOT/wiki/$f" ] && { echo "  Missing: $f"; issues=$((issues + 1)); }
      done

      # ACP client
      [ ! -x "$CPB_ROOT/bridges/acp-client.mjs" ] && { echo "  acp-client.mjs not executable"; issues=$((issues + 1)); }

      # Common.sh
      [ ! -f "$CPB_ROOT/bridges/common.sh" ] && { echo "  common.sh missing"; issues=$((issues + 1)); }

      # Per-project checks
      for dir in "$CPB_ROOT/wiki/projects"/*/; do
        [ -d "$dir" ] || continue
        local name=$(basename "$dir")
        [ "$name" = "_template" ] && continue

        # Boundary violations
        ls "$dir/inbox/deliverable-"*.md &>/dev/null && { echo "  $name: deliverable in inbox"; issues=$((issues + 1)); }
        ls "$dir/outputs/plan-"*.md &>/dev/null && { echo "  $name: plan in outputs"; issues=$((issues + 1)); }

        # Incomplete handoffs (missing Acceptance-Criteria)
        for hf in "$dir/inbox/"*.md "$dir/outputs/"*.md; do
          [ -f "$hf" ] || continue
          [ -s "$hf" ] || continue
          if ! grep -qiE "Acceptance[- ]Criteria|Next-Action" "$hf" 2>/dev/null; then
            echo "  $name: incomplete handoff $(basename "$hf")"
            issues=$((issues + 1))
          fi
        done

        # Stale files (older than 7 days in inbox)
        while read -r stale; do
          [ -z "$stale" ] && continue
          echo "  $name: stale inbox file $(basename "$stale") (>7 days)"
          issues=$((issues + 1))
        done < <(find "$dir/inbox" -name "*.md" -mtime +7 -print 2>/dev/null)
      done

      if [ "$issues" -eq 0 ]; then
        echo -e "  ${GREEN}All checks passed.${NC}"
      else
        echo -e "  ${RED}$issues issue(s)${NC}"
      fi
      ;;
    *)
      echo "Usage: cpb wiki [list|lint]"
      ;;
  esac
}

cmd_cancel() {
  local project="${1:?Usage: cpb cancel <project> <jobId> [reason]}"
  local jobId="${2:?Usage: cpb cancel <project> <jobId> [reason]}"
  shift 2
  local reason="$*"
  CPB_ROOT="$CPB_ROOT" node "$CPB_ROOT/bridges/cancel-redirect.mjs" cancel "$project" "$jobId" "$reason"
}

cmd_redirect() {
  local project="${1:?Usage: cpb redirect <project> <jobId> \"<instructions>\" [reason]}"
  local jobId="${2:?Usage: cpb redirect <project> <jobId> \"<instructions>\" [reason]}"
  local instructions="${3:?Usage: cpb redirect <project> <jobId> \"<instructions>\" [reason]}"
  shift 3
  local reason="$*"
  CPB_ROOT="$CPB_ROOT" node "$CPB_ROOT/bridges/cancel-redirect.mjs" redirect "$project" "$jobId" "$instructions" "$reason"
}

cmd_interop() {
  if command -v omc &>/dev/null; then
    omc interop
  else
    echo -e "${RED}omc not found. Install oh-my-claudecode.${NC}" >&2
    exit 1
  fi
}

cmd_ui() {
  local port="${CPB_PORT:-3456}"
  local host="${CPB_HOST:-127.0.0.1}"
  # Parse flags
  while [ $# -gt 0 ]; do
    case "$1" in
      --port=*) port="${1#--port=}" ;;
      --port) shift; port="${1:-$port}" ;;
      --host=*) host="${1#--host=}" ;;
      --host) shift; host="${1:-$host}" ;;
    esac
    shift
  done

  # Check dependencies
  [ ! -d "$CPB_ROOT/server/node_modules" ] && { echo "Installing server deps..."; cd "$CPB_ROOT/server" && npm install --silent; }
  [ ! -d "$CPB_ROOT/web/node_modules" ] && { echo "Installing web deps..."; cd "$CPB_ROOT/web" && npm install --silent; }

  echo -e "${BOLD}Starting CodePatchbay UI...${NC}"

  # Start backend server
  CPB_PORT="$port" CPB_HOST="$host" node "$CPB_ROOT/server/index.js" &
  local server_pid=$!

  # Start Vite dev server
  cd "$CPB_ROOT/web" && npx vite --port 5173 &
  local vite_pid=$!

  # Wait a moment then open browser
  sleep 2
  if command -v open &>/dev/null; then
    open "http://localhost:5173"
  elif command -v xdg-open &>/dev/null; then
    xdg-open "http://localhost:5173"
  fi

  echo -e "${GREEN}Backend:${NC}  http://localhost:$port"
  echo -e "${GREEN}Frontend:${NC} http://localhost:5173"
  echo -e "${YELLOW}Press Ctrl+C to stop${NC}"

  # Trap exit to kill child processes
  trap "kill $server_pid $vite_pid 2>/dev/null; exit 0" INT TERM
  wait
}

cmd_install() {
  local target="/usr/local/bin/cpb"
  if [ -w "/usr/local/bin" ]; then
    ln -sf "$CPB_ROOT/cpb" "$target"
    echo "Linked: $target -> $CPB_ROOT/cpb"
  else
    echo "Requires sudo:"
    echo "  sudo ln -sf $CPB_ROOT/cpb /usr/local/bin/cpb"
  fi
}

# Main
case "${1:-help}" in
  init)     shift; cmd_init "$@" ;;
  plan)     shift; cmd_plan "$@" ;;
  execute)  shift; cmd_execute "$@" ;;
  verify)   shift; cmd_verify "$@" ;;
  research) shift; cmd_research "$@" ;;
  diff)     shift; cmd_diff "$@" ;;
  pipeline) shift; cmd_pipeline "$@" ;;
  cancel)   shift; cmd_cancel "$@" ;;
  redirect) shift; cmd_redirect "$@" ;;
  status)   shift; cmd_status "$@" ;;
  jobs)     cmd_jobs ;;
  supervisor) cmd_supervisor ;;
  migrate-runtime-root) shift; cmd_migrate_runtime_root "$@" ;;
  list)     cmd_list ;;
  wiki)     shift; cmd_wiki "${1:-list}" ;;
  ui)       shift; cmd_ui "$@" ;;
  interop)  cmd_interop ;;
  install)  cmd_install ;;
  version|--version|-v) echo "cpb v$CPB_VERSION" ;;
  help|--help|-h)
    usage
    echo ""
    check_deps
    ;;
  *)
    echo -e "${RED}Unknown: $1${NC}" >&2
    usage
    exit 1
    ;;
esac
