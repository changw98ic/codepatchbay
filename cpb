          const result = await cleanupJobs(cpbRoot);
          console.log(result.cleaned + ' stale lease(s) cleaned.');
        "
      fi
      ;;
    *)
      CPB_ROOT="$CPB_ROOT" CPB_EXECUTOR_ROOT="$CPB_EXECUTOR_ROOT" "$CPB_EXECUTOR_ROOT/bridges/list-jobs.mjs"
      ;;
  esac
}
cmd_gc() {
  echo -e "${BOLD}Garbage collecting stale runtime data...${NC}"
  CPB_ROOT="$CPB_ROOT" CPB_EXECUTOR_ROOT="$CPB_EXECUTOR_ROOT" node --input-type=module -e "
    import path from 'node:path';
    import { readdir, unlink, stat } from 'node:fs/promises';
    const cpbRoot = path.resolve(process.env.CPB_ROOT || '.');
    const executorRoot = path.resolve(process.env.CPB_EXECUTOR_ROOT || cpbRoot);
    const { listJobs } = await import(path.join(executorRoot, 'server/services/job-store.js'));
    const jobs = await listJobs(cpbRoot);
    const terminal = new Set(['completed','failed','blocked','cancelled']);
    const terminalLeases = jobs.filter(j => terminal.has(j.status) && j.leaseId).map(j => j.leaseId);
    const leasesDir = path.join(cpbRoot, 'cpb-task', 'leases');
    let cleaned = 0;
    try {
      for (const f of await readdir(leasesDir)) {
        if (!f.endsWith('.json')) continue;
        const leaseId = f.replace('.json', '');
        if (terminalLeases.includes(leaseId)) {
          await unlink(path.join(leasesDir, f));
          // Also remove lock dir if present
          try { await unlink(path.join(leasesDir, leaseId + '.lock')); } catch {}
          console.log('  removed lease: ' + leaseId);
          cleaned++;
        }
      }
    } catch {}
    console.log(cleaned + ' stale lease(s) cleaned.');
  "
}
cmd_ps() {
  CPB_ROOT="$CPB_ROOT" CPB_EXECUTOR_ROOT="$CPB_EXECUTOR_ROOT" node --input-type=module - <<'PS_NODE'
import path from "node:path";
const cpbRoot = path.resolve(process.env.CPB_ROOT);
const executorRoot = path.resolve(process.env.CPB_EXECUTOR_ROOT || cpbRoot);
const { listProcesses, classifyLiveness } = await import(path.join(executorRoot, "server/services/process-registry.js"));
const { readLease, isLeaseStale } = await import(path.join(executorRoot, "server/services/lease-manager.js"));

const entries = await listProcesses(cpbRoot);
if (entries.length === 0) { console.log("No CPB-owned processes."); process.exit(0); }

const CYAN = "\x1b[0;36m"; const GREEN = "\x1b[0;32m"; const YELLOW = "\x1b[1;33m"; const RED = "\x1b[0;31m"; const NC = "\x1b[0m";
const livenessColor = { alive: GREEN, stale: YELLOW, orphan: RED, exited: "", stopped: "", unknown: YELLOW };

for (const e of entries) {
  const liveness = classifyLiveness(e);
  const c = livenessColor[liveness] || "";
  let leaseTag = "";
  if (e.leaseId) {
    try {
      const l = await readLease(cpbRoot, e.leaseId);
      leaseTag = l === null ? " lease:missing" : isLeaseStale(l) ? " lease:stale" : " lease:active";
    } catch { leaseTag = " lease:error"; }
  }
  const age = e.startedAt ? Math.round((Date.now() - new Date(e.startedAt).getTime()) / 60000) : "?";
  console.log(`${c}${liveness.padEnd(8)}${NC} ${e.jobId}  project:${e.project || "-"} phase:${e.phase || "-"} pid:${e.runnerPid} age:${age}m${leaseTag}  ${e.command || ""}`);
}
PS_NODE
}

cmd_inspect() {
  local jobId="${1:?Usage: cpb inspect <jobId>}"
  CPB_ROOT="$CPB_ROOT" CPB_EXECUTOR_ROOT="$CPB_EXECUTOR_ROOT" CPB_INSPECT_JOB_ID="$jobId" node --input-type=module - <<'INSPECT_NODE'
import path from "node:path";
const cpbRoot = path.resolve(process.env.CPB_ROOT);
const executorRoot = path.resolve(process.env.CPB_EXECUTOR_ROOT || cpbRoot);
const jobId = process.env.CPB_INSPECT_JOB_ID;
const { inspectProcess } = await import(path.join(executorRoot, "server/services/process-registry.js"));
const result = await inspectProcess(cpbRoot, jobId);
if (!result) { console.error(`Not found: ${jobId}`); process.exit(1); }

const CYAN = "\x1b[0;36m"; const BOLD = "\x1b[1m"; const YELLOW = "\x1b[1;33m"; const NC = "\x1b[0m";
const project = result.job?.project || result.process?.project || null;

// Job section (from durable job state)
if (result.job) {
  console.log(`${BOLD}Job:${NC}`);
  console.log(`  ID:        ${result.job.jobId}`);
  console.log(`  Project:   ${result.job.project || "-"}`);
  console.log(`  Status:    ${result.job.status || "-"}`);
  console.log(`  Phase:     ${result.job.phase || "-"}`);
  console.log(`  Task:      ${(result.job.task || "").slice(0, 80)}`);
  if (result.job.failurePhase) console.log(`  Failed at: ${result.job.failurePhase}`);
  if (result.job.failureCode) console.log(`  Fail code: ${result.job.failureCode}`);
  if (result.job.blockedReason) console.log(`  Reason:    ${result.job.blockedReason}`);
}

// Process section (only if registry entry exists)
if (result.process) {
  console.log(`\n${BOLD}Process:${NC}`);
  console.log(`  PID:       ${result.process.runnerPid}`);
  console.log(`  Liveness:  ${result.liveness}`);
  console.log(`  Status:    ${result.process.status}`);
  console.log(`  Started:   ${result.process.startedAt || "-"}`);
  if (result.process.exitCode !== null) console.log(`  Exit code: ${result.process.exitCode}`);
  if (result.process.command) console.log(`  Command:   ${result.process.command}`);
} else {
  console.log(`\n${YELLOW}Process:${NC} no active process registry entry`);
}

if (result.lease) {
  console.log(`\n${BOLD}Lease:${NC}`);
  console.log(`  ID:        ${result.lease.leaseId}`);
  console.log(`  Phase:     ${result.lease.phase || "-"}`);
  console.log(`  Stale:     ${result.lease.stale}`);
  console.log(`  Expires:   ${result.lease.expiresAt || "-"}`);
}

if (result.recentEvents.length > 0) {
  console.log(`\n${BOLD}Recent events (${result.recentEvents.length}):${NC}`);
  for (const ev of result.recentEvents.slice(-5)) {
    console.log(`  ${ev.type} ${ev.phase || ""} ${ev.ts || ""}`);
  }
}

// Lineage: parent with failure context
if (result.lineage) {
  console.log(`\n${BOLD}Lineage:${NC}`);
  console.log(`  Parent:    ${result.lineage.parentJobId || "-"}`);
  console.log(`  Parent status: ${result.lineage.parentStatus || "-"}`);
  if (result.lineage.parentFailurePhase) console.log(`  Parent failed at: ${result.lineage.parentFailurePhase}`);
  if (result.lineage.parentFailureCode) console.log(`  Parent fail code: ${result.lineage.parentFailureCode}`);
  if (result.lineage.parentBlockedReason) console.log(`  Parent blocked:   ${result.lineage.parentBlockedReason}`);
  if (result.lineage.recoveryReason) console.log(`  Recovery reason:  ${result.lineage.recoveryReason}`);
}

// Ancestors (bounded depth 5)
if (result.ancestors && result.ancestors.length > 0) {
  console.log(`\n${BOLD}Ancestors:${NC}`);
  for (const a of result.ancestors) {
    const fail = a.failurePhase ? ` failed:${a.failurePhase}` : "";
    const code = a.failureCode ? ` code:${a.failureCode}` : "";
    console.log(`  ${a.jobId} (${a.status}${fail}${code})`);
  }
}

// Children (recovery jobs spawned from this one)
if (result.children && result.children.length > 0) {
  console.log(`\n${BOLD}Recovery children (${result.children.length}):${NC}`);
  for (const c of result.children) {
    console.log(`  ${c.jobId} (${c.status})`);
  }
}
INSPECT_NODE
}

