}
cmd_hub_start() {
  CPB_ROOT="$CPB_ROOT" CPB_EXECUTOR_ROOT="$CPB_EXECUTOR_ROOT" node --input-type=module - <<'NODE'
import path from 'node:path';
import { openSync } from 'node:fs';
import { readFile, mkdir, stat } from 'node:fs/promises';
import { spawn } from 'node:child_process';
const cpbRoot = path.resolve(process.env.CPB_ROOT);
const executorRoot = path.resolve(process.env.CPB_EXECUTOR_ROOT || cpbRoot);
const { resolveHubRoot } = await import(path.join(executorRoot, 'server/services/hub-registry.js'));
const hubRoot = resolveHubRoot(cpbRoot);
const statePath = path.join(hubRoot, 'state', 'hub.json');

// Check existing liveness
let alive = false;
let existingPid = null;
try {
  const raw = await readFile(statePath, 'utf8');
  const meta = JSON.parse(raw);
  if (meta.health !== 'dead') {
    try { process.kill(meta.pid, 0); alive = true; existingPid = meta.pid; } catch {}
  }
} catch {}

if (alive) {
  console.log(`Hub is already running (pid: ${existingPid}).`);
  process.exit(0);
}

// Ensure server deps
try { await stat(path.join(executorRoot, 'server', 'node_modules')); }
catch {
  console.log('Installing server deps...');
  const { execSync } = await import('node:child_process');
  execSync('npm install --silent', { cwd: path.join(executorRoot, 'server'), stdio: 'pipe' });
}

const port = process.env.CPB_PORT || '3456';
const host = process.env.CPB_HOST || '127.0.0.1';
await mkdir(hubRoot, { recursive: true });
const logFd = openSync(path.join(hubRoot, 'hub.log'), 'a');
const child = spawn(process.execPath, [path.join(executorRoot, 'server', 'index.js')], {
  cwd: cpbRoot,
  env: { ...process.env, CPB_ROOT: cpbRoot, CPB_EXECUTOR_ROOT: executorRoot, CPB_HUB_ROOT: hubRoot, CPB_PORT: port, CPB_HOST: host },
  detached: true,
  stdio: ['ignore', logFd, logFd],
});
child.unref();

// Wait for hub.json (up to 5s)
for (let i = 0; i < 50; i++) {
  await new Promise(r => setTimeout(r, 100));
  try {
    const raw = await readFile(statePath, 'utf8');
    const meta = JSON.parse(raw);
    if (meta.health === 'alive') {
      console.log(`Hub started on http://${host}:${port} (pid: ${meta.pid})`);
      process.exit(0);
    }
  } catch {}
}
console.error(`Hub failed to start within 5 seconds. Check ${path.join(hubRoot, 'hub.log')}`);
process.exit(1);
NODE
}

cmd_hub_stop() {
  CPB_ROOT="$CPB_ROOT" CPB_EXECUTOR_ROOT="$CPB_EXECUTOR_ROOT" node --input-type=module - <<'NODE'
import path from 'node:path';
import { readFile } from 'node:fs/promises';
const cpbRoot = path.resolve(process.env.CPB_ROOT);
const executorRoot = path.resolve(process.env.CPB_EXECUTOR_ROOT || cpbRoot);
const { resolveHubRoot } = await import(path.join(executorRoot, 'server/services/hub-registry.js'));
const hubRoot = resolveHubRoot(cpbRoot);
const statePath = path.join(hubRoot, 'state', 'hub.json');

let meta;
try { meta = JSON.parse(await readFile(statePath, 'utf8')); }
catch { console.log('Hub is not running (no state file).'); process.exit(0); }

if (meta.health === 'dead') {
  console.log('Hub is not running (graceful shutdown recorded).');
  process.exit(0);
}

try { process.kill(meta.pid, 0); }
catch { console.log(`Hub process ${meta.pid} is not running.`); process.exit(0); }

process.kill(meta.pid, 'SIGTERM');

// Wait for shutdown (up to 5s)
for (let i = 0; i < 50; i++) {
  await new Promise(r => setTimeout(r, 100));
  try { process.kill(meta.pid, 0); } catch {
    console.log(`Hub stopped (was pid: ${meta.pid}).`);
    process.exit(0);
  }
}
try { process.kill(meta.pid, 9); } catch {}
console.log(`Hub force-stopped (was pid: ${meta.pid}).`);
NODE
}

cmd_hub() {
  local sub="${1:-status}"
  local json=0
  shift || true
  while [ $# -gt 0 ]; do
    case "$1" in
      --json) json=1 ;;
      *) echo -e "${RED}Unknown hub flag: $1${NC}" >&2; exit 1 ;;
    esac
    shift
  done
  case "$sub" in
    start) cmd_hub_start; return $? ;;
    stop)  cmd_hub_stop;  return $? ;;
  esac
  CPB_ROOT="$CPB_ROOT" CPB_EXECUTOR_ROOT="$CPB_EXECUTOR_ROOT" CPB_HUB_JSON="$json" CPB_HUB_SUB="$sub" node --input-type=module - <<'NODE'
import path from 'node:path';
const cpbRoot = path.resolve(process.env.CPB_ROOT);
const executorRoot = path.resolve(process.env.CPB_EXECUTOR_ROOT || cpbRoot);
const sub = process.env.CPB_HUB_SUB || 'status';
const asJson = process.env.CPB_HUB_JSON === '1';
const { hubStatus, listProjects, resolveHubRoot, workerStatus } = await import(path.join(executorRoot, 'server/services/hub-registry.js'));
const { readHubLiveness } = await import(path.join(executorRoot, 'server/services/hub-runtime.js'));
const hubRoot = resolveHubRoot(cpbRoot);
if (sub === 'status') {
  const status = await hubStatus(hubRoot);
  const liveness = await readHubLiveness(hubRoot);
  if (asJson) console.log(JSON.stringify({ ...status, liveness }, null, 2));
  else {
    const liveTag = liveness.alive ? 'alive' : `down (${liveness.reason})`;
    console.log(`Hub: ${status.hubRoot}`);
    console.log(`Server: ${liveTag}`);
    console.log(`Projects: ${status.enabledProjectCount}/${status.projectCount} enabled`);
    console.log(`Workers: ${status.workersOnline} online, ${status.workersStale} stale, ${status.workersOffline} offline`);
  }
} else if (sub === 'projects') {
  const projects = await listProjects(hubRoot);
  if (asJson) console.log(JSON.stringify(projects, null, 2));
  else {
    if (projects.length === 0) console.log('No Hub projects. Run: cpb attach [path] [name]');
    for (const project of projects) {
      const worker = project.worker?.lastSeenAt ? ` worker:${workerStatus(project)}` : '';
      console.log(`${project.enabled === false ? '-' : '+'} ${project.id}\t${project.sourcePath}${worker}`);
    }
  }
} else if (sub === 'acp') {
  const { getManagedAcpPool } = await import(path.join(executorRoot, 'server/services/acp-pool-runtime.js'));
  const pool = getManagedAcpPool({ cpbRoot, hubRoot });
  const status = { ...pool.status(), rateLimits: await pool.readDurableRateLimits() };
  if (asJson) console.log(JSON.stringify(status, null, 2));
  else {
    console.log('ACP pools:');
    for (const [agent, info] of Object.entries(status.pools || {})) {
      const limit = status.rateLimits?.[agent];
      const backoff = limit?.untilTs ? ` backoff:${limit.untilTs}` : '';
      console.log(`  ${agent}\tmode:${info.mode} limit:${info.limit} active:${info.active} queued:${info.queued}${backoff}`);
    }
    const extra = Object.keys(status.rateLimits || {}).filter((agent) => !status.pools?.[agent]);
    for (const agent of extra) {
      console.log(`  ${agent}\tbackoff:${status.rateLimits[agent].untilTs}`);
    }
  }
} else if (sub === 'queue' || sub === 'queue-status') {
  const { listQueue, queueStatus } = await import(path.join(executorRoot, 'server/services/hub-queue.js'));
  if (sub === 'queue-status') {
    const qs = await queueStatus(hubRoot);
    if (asJson) console.log(JSON.stringify(qs, null, 2));
    else {
      console.log(`Queue: ${qs.total} entries`);
      console.log(`  pending:${qs.pending} in_progress:${qs.inProgress} completed:${qs.completed} failed:${qs.failed} cancelled:${qs.cancelled}`);
    }
  } else {
    const entries = await listQueue(hubRoot);
    if (asJson) console.log(JSON.stringify(entries, null, 2));
    else {
      if (entries.length === 0) console.log('Queue is empty');
      for (const e of entries) {
        console.log(`${e.status}\t${e.priority}\t${e.projectId}\t${e.description || e.id}`);
      }
    }
  }
} else if (sub === 'diagnostics') {
  const { gatherDiagnostics } = await import(path.join(executorRoot, 'server/services/diagnostics-bundle.js'));
  const diag = await gatherDiagnostics({ cpbRoot, hubRoot });
  if (asJson) console.log(JSON.stringify(diag, null, 2));
  else {
    console.log(`Diagnostics gathered at: ${diag.gatheredAt}`);
    console.log(`Hub: ${diag.hub.hubRoot}`);
    console.log(`Projects: ${diag.hub.enabledProjectCount}/${diag.hub.projectCount} enabled`);
    console.log(`Workers: ${diag.hub.workersOnline} online, ${diag.hub.workersStale} stale, ${diag.hub.workersOffline} offline`);
    console.log(`Queue: ${diag.queue.total} (${diag.queue.pending} pending, ${diag.queue.inProgress} active)`);
    const pools = diag.acp?.pools || {};
    for (const [agent, info] of Object.entries(pools)) {
      const rl = diag.acp?.rateLimits?.[agent];
      const backoff = rl?.untilTs ? ` backoff:${rl.untilTs}` : '';
      console.log(`ACP ${agent}: active:${info.active} queued:${info.queued} requests:${info.requestCount}${backoff}`);
    }
    console.log(`Recent jobs: ${diag.recentJobs.length}`);
    for (const job of diag.recentJobs) {
      console.log(`  ${job.jobId} ${job.status} ${job.project} phase:${job.currentPhase || '-'}`);
    }
    if (diag.errors?.length) {
      console.log(`Errors: ${diag.errors.length}`);
      for (const e of diag.errors) console.log(`  ${e.source}: ${e.message}`);
    }
  }
} else {
  console.error(`Unknown hub subcommand: ${sub}`);
  process.exit(1);
}
NODE
}
cmd_worker() {
  local sub="${1:-heartbeat}"
  shift || true
  case "$sub" in
    heartbeat)
      local project_path
      project_path="$(resolve_repo_root "${1:-$PWD}")"
      local project_name="${2:-}"
      CPB_ROOT="$CPB_ROOT" CPB_EXECUTOR_ROOT="$CPB_EXECUTOR_ROOT" CPB_HUB_ROOT="${CPB_HUB_ROOT:-}" PROJECT_PATH="$project_path" PROJECT_NAME="$project_name" node --input-type=module - <<'NODE'
import path from 'node:path';
const cpbRoot = path.resolve(process.env.CPB_ROOT);
const executorRoot = path.resolve(process.env.CPB_EXECUTOR_ROOT || cpbRoot);
const sourcePath = path.resolve(process.env.PROJECT_PATH || process.cwd());
const name = process.env.PROJECT_NAME || path.basename(sourcePath);
const { heartbeatWorker, registerProject, resolveHubRoot } = await import(path.join(executorRoot, 'server/services/hub-registry.js'));
const hubRoot = resolveHubRoot(cpbRoot);
const project = await registerProject(hubRoot, { name, sourcePath });
const updated = await heartbeatWorker(hubRoot, project.id, {
  workerId: `cli-${process.pid}`,
  pid: process.pid,
  status: 'online',
  capabilities: ['scan', 'execute'],
});
console.log(JSON.stringify({ heartbeat: true, hubRoot, project: updated }, null, 2));
NODE
      ;;
    run)
      local project_path="$PWD"
      if [ $# -gt 0 ] && [[ "$1" != --* ]]; then
        project_path="$1"
        shift
      fi
      project_path="$(resolve_repo_root "$project_path")"
      local project_name=""
      if [ $# -gt 0 ] && [[ "$1" != --* ]]; then
        project_name="$1"
        shift
      fi
      local worker_args_json
      worker_args_json="$(node -e 'process.stdout.write(JSON.stringify(process.argv.slice(1)))' -- "$@")"
      # Register project first, then start worker with its ID
      CPB_ROOT="$CPB_ROOT" CPB_EXECUTOR_ROOT="$CPB_EXECUTOR_ROOT" CPB_HUB_ROOT="${CPB_HUB_ROOT:-}" PROJECT_PATH="$project_path" PROJECT_NAME="$project_name" WORKER_ARGS_JSON="$worker_args_json" node --input-type=module - <<'NODE'
import path from 'node:path';
const cpbRoot = path.resolve(process.env.CPB_ROOT);
const executorRoot = path.resolve(process.env.CPB_EXECUTOR_ROOT || cpbRoot);
const sourcePath = path.resolve(process.env.PROJECT_PATH || process.cwd());
const name = process.env.PROJECT_NAME || path.basename(sourcePath);
const { registerProject, resolveHubRoot } = await import(path.join(executorRoot, 'server/services/hub-registry.js'));
const hubRoot = resolveHubRoot(cpbRoot);
const project = await registerProject(hubRoot, { name, sourcePath });
const args = JSON.parse(process.env.WORKER_ARGS_JSON || '[]');
const nodeArgs = ['--project', project.id, ...args];
const { spawn } = await import('node:child_process');
const child = spawn(process.execPath, [path.join(executorRoot, 'bridges', 'project-worker.mjs'), ...nodeArgs], {
  cwd: cpbRoot,
  env: { ...process.env, CPB_ROOT: cpbRoot, CPB_EXECUTOR_ROOT: executorRoot, CPB_HUB_ROOT: hubRoot },
  stdio: 'inherit',
});
child.on('close', (code) => process.exit(code));
child.on('error', (err) => { console.error(err.message); process.exit(1); });
NODE
      ;;
    *)
      echo -e "${RED}Usage: cpb worker <heartbeat|run> [path] [name] [flags]${NC}" >&2
      exit 1
      ;;
  esac
}
