{
  "name": "codepatchbay",
  "version": "0.4.1",
  "description": "Local delivery runtime for coding agents with ACP orchestration, evidence tracking, and reviewable artifacts.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/changw98ic/codepatchbay.git"
  },
  "homepage": "https://github.com/changw98ic/codepatchbay#readme",
  "bugs": {
    "url": "https://github.com/changw98ic/codepatchbay/issues"
  },
  "type": "module",
  "bin": {
    "cpb": "cpb"
  },
  "files": [
    "cpb",
    "dist/",
    "profiles/",
    "skills/",
    "templates/",
    "wiki/schema.md",
    "README.md",
    "docs/",
    "!dist/tests/",
    "!dist/server/.omc/",
    "!dist/wiki/system/",
    "!wiki/system/",
    "!core/**/*.tmp",
    "!*.tgz"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "prepack": "npm run build",
    "pretest:node": "npm run build:node && npm run build:tests",
    "test": "npm run test:node && npm run test:shell",
    "test:node": "node dist-tests/scripts/run-node-tests.js",
    "test:shell": "bash tests/cpb-bridges.test.sh && bash tests/cpb-jobs.test.sh",
    "test:unit": "node dist-tests/scripts/run-node-tests.js --unit",
    "test:integration": "node dist-tests/scripts/run-node-tests.js --integration",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.tests.json --noEmit",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.tests.json --noEmit",
    "typecheck:strict:engine": "tsc -p tsconfig.strict-engine.json --noEmit",
    "typecheck:type-debt:engine": "npm run build:node && node dist/scripts/type-debt-guard.js",
    "verify:dependency-audit": "npm audit --omit=dev --audit-level=moderate && npm audit --audit-level=high",
    "verify:patch-integrity": "npm run build:node && node dist/scripts/verify-patch-integrity.js",
    "verify:commit-size": "npm run build:node && node dist/scripts/verify-commit-size.js",
    "verify:product-gate": "npm run build:node && node dist/scripts/verify-product-gate.js",
    "promote:live-release-evidence": "npm run build:node && node dist/scripts/promote-live-release-evidence.js",
    "validate:swebench-product": "npm run build:node && node dist/scripts/run-swebench-product-validation.js",
    "compare:coding": "npm run build:node && node dist/scripts/run-coding-comparison.js",
    "queue:swebench-batch": "npm run build:node && node dist/scripts/queue-swebench-batch.js",
    "compare:swebench-three-way": "npm run build:node && node dist/scripts/run-swebench-three-way.js",
    "verify:stabilization": "npm run build && npm run build:tests && node dist/scripts/verify-stabilization.js",
    "report:release-readiness": "npm run build:node && node dist/scripts/release-readiness-report.js",
    "verify:live-release-evidence": "npm run build:node && node dist/scripts/verify-live-release-evidence.js",
    "rehearse:disposable-draft-pr": "npm run build:node && node dist/scripts/rehearse-disposable-draft-pr.js",
    "build:node": "test -f tsconfig.node.json && test -f scripts/write-dist-metadata.ts && test -f scripts/build-output.mjs || { echo \"build:node must run from the source checkout; refusing to remove dist\" >&2; exit 1; } && node scripts/build-output.mjs node",
    "build:tests": "test -f tsconfig.tests.json && test -f tsconfig.node.json && test -f scripts/build-output.mjs || { echo \"build:tests must run from the source checkout; refusing to remove dist-tests\" >&2; exit 1; } && node scripts/build-output.mjs tests",
    "build": "npm run build:node",
    "verify:p0p1": "npm run build && npm run build:tests && node dist/scripts/verify-p0-p1.js",
    "verify:enterprise-gate": "npm run build && npm run build:tests && node dist/scripts/verify-enterprise-gate.js",
    "verify:release-gate": "npm run build && npm run build:tests && node dist/scripts/verify-release-gate.js"
  },
  "dependencies": {
    "chokidar": "4.0.3"
  },
  "devDependencies": {
    "@types/node": "25.9.3",
    "typescript": "6.0.3"
  },
  "bundleDependencies": [
    "chokidar"
  ]
}
