{
  "name": "codepatchbay",
  "version": "0.3.1",
  "type": "module",
  "bin": {
    "cpb": "cpb"
  },
  "files": [
    "cpb",
    "cli/",
    "bridges/",
    "core/",
    "runtime/",
    "server/index.js",
    "server/orchestrator/",
    "server/routes/",
    "server/services/",
    "server/notification/",
    "profiles/",
    "skills/",
    "templates/",
    "wiki/schema.md",
    "wiki/system/",
    "web/dist/",
    "scripts/",
    "README.md",
    "docs/demo.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "prepack": "npm run build:pack --workspace codepatchbay-web",
    "pretest:node": "npm run build:pack --workspace codepatchbay-web",
    "test": "npm run test:node",
    "test:node": "node scripts/run-node-tests.mjs",
    "build:web": "npm run build --workspace codepatchbay-web",
    "verify:p0p1": "node scripts/verify-p0-p1.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/websocket": "^11.0.0",
    "@sylphx/coderag-mcp": "^0.3.33",
    "chokidar": "^4.0.0",
    "fastify": "^5.0.0",
    "glob": "^11.0.0",
    "supergateway": "^3.4.3"
  }
}
