# Auto detect text files and perform LF normalization
*        text=auto
*.mjs    text eol=lf
*.js     text eol=lf
*.jsx    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.sh     text eol=lf
*.svg    text eol=lf

# Windows scripts should use CRLF
*.bat    text eol=crlf
*.cmd    text eol=crlf

# Binary files
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.pdf    binary
*.zip    binary
*.gz     binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary

# Large generated files — exclude from diffs and statistics
package-lock.json linguist-generated=true -diff

# Preserve frozen, hash-bound unified diff evidence without whitespace diagnostics.
docs/product/evidence/swe-bench-real-runs/verified-5-codex-runtime-official-score-artifacts/patches/*.patch -whitespace
