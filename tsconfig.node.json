{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "sourceMap": false,
    "declaration": false,
    "noEmitOnError": false
  },
  "include": [
    "cli/**/*.ts",
    "core/**/*.ts",
    "server/**/*.ts",
    "runtime/**/*.ts",
    "bridges/**/*.ts",
    "shared/**/*.ts",
    "scripts/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "web",
    "tests"
  ]
}
