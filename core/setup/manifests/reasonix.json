{
  "id": "reasonix",
  "displayName": "Reasonix",
  "vendor": "esengine (DeepSeek)",
  "binary": "reasonix",
  "tier": 1,
  "recommended": true,
  "roles": ["executor", "planner", "reviewer"],
  "capabilities": ["repo_inspect", "file_edit", "shell", "verify", "large_context"],
  "sourceUrl": "https://github.com/esengine/DeepSeek-Reasonix",
  "install": {
    "npm": {
      "label": "npm",
      "command": "npm i -g reasonix",
      "pinnedCommandTemplate": "npm i -g reasonix@{version}",
      "sourceUrl": "https://github.com/esengine/DeepSeek-Reasonix"
    },
    "brew": {
      "label": "Homebrew",
      "command": "brew install esengine/reasonix/reasonix",
      "sourceUrl": "https://github.com/esengine/DeepSeek-Reasonix"
    }
  },
  "upgrade": {
    "npm": {
      "label": "npm upgrade",
      "command": "npm update -g reasonix",
      "sourceUrl": "https://github.com/esengine/DeepSeek-Reasonix"
    },
    "brew": {
      "label": "Homebrew upgrade",
      "command": "brew upgrade esengine/reasonix/reasonix",
      "sourceUrl": "https://github.com/esengine/DeepSeek-Reasonix"
    }
  },
  "auth": {
    "methods": ["provider_api_key", "setup_wizard"],
    "connectCommand": "reasonix setup",
    "statusCommand": "reasonix doctor"
  },
  "adapter": {
    "protocol": "acp",
    "command": "reasonix",
    "args": ["acp"]
  }
}
