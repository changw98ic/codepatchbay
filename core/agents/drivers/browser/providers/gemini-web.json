{
  "schemaVersion": 1,
  "name": "gemini-web",
  "aliases": ["gemini"],
  "displayName": "Gemini",
  "support": { "tier": "experimental", "requiresManualLogin": true, "lastVerified": null },
  "startUrl": "https://gemini.google.com",
  "auth": {
    "type": "persistent-profile",
    "loginUrl": "https://gemini.google.com",
    "loginCheck": { "mode": "selector-visible", "selector": "a:has-text('Sign in')" },
    "readyCheck": { "mode": "selector-visible", "selector": "textarea" }
  },
  "input": {
    "selector": "textarea",
    "kind": "textarea",
    "method": "fill",
    "clearBeforeInput": true,
    "submit": { "mode": "enter" }
  },
  "response": {
    "messageSelector": ".assistant-message",
    "textSelector": null,
    "mode": "last-message",
    "stableRounds": 2,
    "minChars": 10,
    "pollIntervalMs": 2000,
    "maxWaitMs": 900000,
    "doneWhen": [{ "type": "text-stable", "rounds": 2 }]
  },
  "continue": { "enabled": false },
  "diagnostics": { "screenshotOnFailure": true, "traceOnFailure": false }
}
