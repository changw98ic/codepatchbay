{
  "schemaVersion": 1,
  "name": "mock",
  "displayName": "Mock Provider",
  "support": { "tier": "official", "requiresManualLogin": false, "lastVerified": null },
  "startUrl": "fixture:mock-chat.html",
  "auth": {
    "type": "persistent-profile",
    "loginUrl": "fixture:dev-null.html",
    "loginCheck": { "mode": "selector-visible", "selector": ".never-exists" },
    "readyCheck": { "mode": "selector-visible", "selector": "#mock-textarea" }
  },
  "input": {
    "selector": "#mock-textarea",
    "kind": "textarea",
    "method": "fill",
    "clearBeforeInput": true,
    "submit": { "mode": "button", "selector": "#mock-send" }
  },
  "response": {
    "messageSelector": ".mock-message",
    "textSelector": ".mock-text",
    "mode": "last-message",
    "stableRounds": 1,
    "minChars": 5,
    "pollIntervalMs": 500,
    "maxWaitMs": 30000,
    "doneWhen": [{ "type": "text-stable", "rounds": 1 }]
  },
  "continue": { "enabled": true, "selector": "#mock-continue", "maxClicks": 2, "cooldownMs": 500 },
  "diagnostics": { "screenshotOnFailure": false, "traceOnFailure": false }
}
